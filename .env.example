# 请复制本文件为 .env，并填入你的配置

# ── 访问密码（用户名和密码都填写才会启用登录验证）──
AUTH_USER=admin
AUTH_PASSWORD=

# ── iCal 日历订阅令牌（填写后开启 /calendar/<令牌>.ics 订阅源）──
# 建议用随机字符串，例如 openssl rand -hex 16 生成
CALENDAR_TOKEN=

# ── 服务监听（本地开发可留默认）──
# HOST=127.0.0.1
# PORT=5001

# ── 数据库路径 ──
# DB_PATH=homework.db

# ── OpenAI（OCR 截图识别，可选）──
OPENAI_API_KEY=sk-your-key-here

# 如果使用国内中转或其他兼容接口，修改此地址
OPENAI_BASE_URL=https://api.openai.com/v1

# 推荐使用 gpt-4o-mini（便宜且够用）
OPENAI_MODEL=gpt-4o-mini
